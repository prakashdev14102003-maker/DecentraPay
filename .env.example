# ─── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://decentrapay:devpass@localhost:5432/decentrapay

# ─── Auth ──────────────────────────────────────────────
JWT_SECRET=change-me-32-byte-hex-secret-key-here
JWT_REFRESH_SECRET=change-me-another-32-byte-hex-key
BCRYPT_ROUNDS=12

# ─── Blockchain ────────────────────────────────────────
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
DEPLOYER_PRIVATE_KEY=0x...
CARBON_CREDIT_PROXY=0x...
REGISTRY_PROXY=0x...
MARKETPLACE_PROXY=0x...
TREASURY_ADDRESS=0x...
ETHERSCAN_API_KEY=...

# ─── Frontend (Next.js) ───────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_SEPOLIA_CHAIN_ID=11155111
NEXT_PUBLIC_CARBON_CREDIT_PROXY=0x...
NEXT_PUBLIC_MARKETPLACE_PROXY=0x...

# ─── Server ────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ─── Tolerances ────────────────────────────────────────
DEFAULT_TOLERANCE_PCT=2.0
