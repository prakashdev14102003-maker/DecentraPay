    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.18",
        "@types/express": "^5.0.2",
        "@types/jsonwebtoken": "^9.0.9",
        "@types/multer": "^1.4.12",
        "@types/node": "^25.6.0",
        "@types/pg": "^8.11.14",
        "drizzle-kit": "^0.31.1",
        "tsx": "^4.19.4",
