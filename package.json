{
  "name": "decentrapay",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "bun run --filter @decentrapay/api db:generate",
    "db:migrate": "bun run --filter @decentrapay/api db:migrate",
    "db:push": "bun run --filter @decentrapay/api db:push",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "turbo": "^2.4.4"
  },
  "packageManager": "bun@1.3.2"
}
