{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "moduleResolution": "node",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "outDir": "dist",
        "resolveJsonModule": true
    },
    "include": [
        "hardhat.config.ts",
        "scripts",
        "test"
    ],
    "exclude": [
        "node_modules",
        "artifacts",
        "cache"
    ]
}